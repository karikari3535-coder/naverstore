# ⚠️ 이 파일은 템플릿입니다. 복사해서 .env.local 로 만든 뒤 값을 채우세요.
#    cp .env.local.example .env.local
#    .env.local 은 절대 git 에 커밋하지 마세요.

# ── (A) 네이버 검색광고 API (키워드 검색량·경쟁도) ──
# 발급: searchad.naver.com → 도구 → API 사용 관리
NAVER_API_KEY=
NAVER_SECRET_KEY=
NAVER_CUSTOMER_ID=

# ── (B) 네이버 검색(쇼핑) API (상위 40개 상품명·카테고리) ──
# 발급: developers.naver.com → 애플리케이션 등록 → 사용 API "검색" 선택
# ※ 사이트 URL 이 필요하므로, 배포 후 도메인이 나오면 발급해서 채웁니다.
NAVER_SHOP_ID=
NAVER_SHOP_SECRET=
